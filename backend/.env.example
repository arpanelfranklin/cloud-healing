# ─────────────────────────────────────────────────────────────────────────
# SelfHeal Backend — Environment Variables
# Copy this to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── AI Providers (at least one required unless ALLOW_AI_MOCK=true) ────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Set to true to use realistic mock AI responses (no API key needed)
ALLOW_AI_MOCK=false

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000

# ── CORS (set to your Vercel URL in production) ───────────────────────────
# FRONTEND_URL=https://your-app.vercel.app
